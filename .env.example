# .env.example — GI Data Lakehouse
# Copier vers .env.local et remplir les valeurs
# JAMAIS committer .env.local dans git

# === Evolia SQL Server lecture seule ===
EVOLIA_SERVER=SRV-SQL2\cegi
EVOLIA_DB=INTERACTION
EVOLIA_USER=srv_data_read_analyst
EVOLIA_PASSWORD="kM@xspzt45dC$7gGoH"

# === OVHcloud Object Storage S3 ===
OVH_S3_ENDPOINT=https://s3.gra.perf.cloud.ovh.net
OVH_S3_ACCESS_KEY=
OVH_S3_SECRET_KEY=
BUCKET_BRONZE=gi-poc-bronze
BUCKET_SILVER=gi-poc-silver

# === PostgreSQL Gold Warehouse ===
PG_HOST=gi-poc-warehouse.postgresql.ovh.net
PG_PORT=5432
PG_USER=
PG_PASSWORD=
PG_DATABASE=gi_lakehouse

# === RGPD ===
# Salt pour pseudonymisation NIR — minimum 32 caractères, UNIQUE par environnement
RGPD_SALT=

# === Enrichissement externe ===
SIRENE_API_TOKEN=
SALESFORCE_ENABLED=0

# === Mode ===
DRY_RUN=0

# === DataHub (optionnel) ===
DATAHUB_SERVER=http://localhost:8080
DATAHUB_TOKEN=

# === Superset URL (documentation only) ===
SUPERSET_URL=https://gi-poc-platform.dataplatform.ovh.net/superset
