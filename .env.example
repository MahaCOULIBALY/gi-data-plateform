# .env.example — GI Data Lakehouse
# Copier vers .env et remplir les valeurs réelles.
# JAMAIS committer .env dans git — il est dans .gitignore.
#
# Noms de variables : source de vérité = scripts/shared.py (classe Config)

# ── Evolia SQL Server (lecture seule) ──────────────────────────────────────────
# Format pymssql : "hostname,port"  (ex: "SRV-SQL2,1433")
EVOLIA_SERVER=SRV-SQL2,1433
EVOLIA_DB=INTERACTION
EVOLIA_USER=srv_data_read_analyst
EVOLIA_PASSWORD=

# ── OVHcloud Object Storage S3 ────────────────────────────────────────────────
OVH_S3_ENDPOINT=https://s3.gra.perf.cloud.ovh.net
OVH_S3_ACCESS_KEY=
OVH_S3_SECRET_KEY=

# Noms des buckets (ces valeurs sont les défauts de shared.py — ne définir que pour les overrider)
OVH_S3_BUCKET_BRONZE=gi-data-prod-bronze
OVH_S3_BUCKET_SILVER=gi-data-prod-silver
OVH_S3_BUCKET_GOLD=gi-data-prod-gold

# ── OVHcloud Iceberg REST (couche Silver Iceberg) ─────────────────────────────
BUCKET_ICEBERG=gi-data-prod-iceberg
OVH_ICEBERG_URI=https://iceberg.gra.io.cloud.ovh.net/
OVH_ICEBERG_CATALOG=silver

# ── PostgreSQL Gold Warehouse ─────────────────────────────────────────────────
OVH_PG_HOST=postgresql-161a1420-of9dcfaf6.database.cloud.ovh.net
OVH_PG_PORT=20184
OVH_PG_USER=
OVH_PG_PASSWORD=
OVH_PG_DATABASE=gi_data

# ── RGPD ──────────────────────────────────────────────────────────────────────
# OBLIGATOIRE en LIVE et PROBE. Minimum 32 caractères. UNIQUE par environnement.
RGPD_SALT=

# ── Mode d'exécution ──────────────────────────────────────────────────────────
# offline | probe | live   (défaut : live si absent)
RUN_MODE=live

# ── Filtrage tables (debug / backfill sélectif) ───────────────────────────────
# TABLE_FILTER=WTMET,WTQUA

# ── Partition Silver (override date du jour pour backfill) ────────────────────
# SILVER_DATE_PARTITION=2026/03/10
# SILVER_DATE_PARTITION=**   # full-history après purge Bronze

# ── Enrichissement externe ────────────────────────────────────────────────────
# Token Bearer pour l'API SIRENE INSEE (bronze_clients_external.py)
# Si absent : l'enrichissement SIRENE est skippé (warning non-bloquant).
# Procédure d'obtention : voir docs/DEPLOY.md §8 "SIRENE_API_TOKEN"
SIRENE_API_TOKEN=

# Salesforce (bronze_clients_external.py → silver_clients.py → gold dim_clients.naf_libelle)
# Activer : SALESFORCE_ENABLED=1 + renseigner les 4 credentials ci-dessous.
# Si désactivé (=0) : run_salesforce skippé, silver_clients utilise naf_libelle=NULL.
# SF_DOMAIN : "login" (production) ou "test" (sandbox)
SALESFORCE_ENABLED=0
SF_USERNAME=
SF_PASSWORD=
SF_CONSUMER_KEY=
SF_CONSUMER_SECRET=
SF_DOMAIN=login

# ── Alertes ───────────────────────────────────────────────────────────────────
ALERT_EMAIL=data-team@groupe-interaction.fr
